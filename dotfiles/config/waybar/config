{
    "layer": "top",
    "position": "top", // Waybar position (top|bottom|left|right)
    //"height": 22, // Waybar height
    //"width": 120, // Waybar width
    "margin-left": 0,
    "margin-right": 0,
    "margin-top": 2,
    "margin-bottom": 2,
    "modules-left": ["hyprland/workspaces" ],
    "modules-right": [
    	"custom/timew",
    	"pulseaudio", 
	"cpu", 
	"memory", 
	"temperature", 
	"backlight", 
	"battery", 
	"clock", 
	"network", 
	"tray",
	],
    "reload_style_on_change": true,

    "hyprland/workspaces": {
	"format": " {name} ",
    },

    "tray": {
        "icon-size": 16,
        "spacing": 3
    },

    "clock": {
        //"format": "{:%I:%M %p}",
        "rotate": 0,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
	    "week-start": 1,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": " {usage}%"
    },

    "memory": {
        "format": " {}%"
    },

    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": " {temperatureC}°C",
        "format": " {temperatureC}°C"
    },

    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon}   {percent}%",
	"format-icons": ["󰃞", "󰃝", "󰃟", "󰃠"],
	//"min-length": 4
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
	"format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
	"on-click-right": "killall -SIGUSR2 waybar"
    },

    "network": {
        "tooltip": true,
        "format-wifi": "{icon} ",
        "format-icons": ["󰤟", "󰤢", "󰤥", "󰤨"],
//  "format-wifi": "<i class='fa-solid fa-wifi-slash'></i>",
        "rotate": 0,
        "format-ethernet": "󰈀 ",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "format-linked": "󰈀 {ifname} (No IP)",
        "format-disconnected": " ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 10
    },

    "custom/timew": {
        "exec": "~/.config/waybar/timew-waybar.sh",
        "interval": 5,
        "return-type": "json",
        "format": "{}",
        "signal": 10,
        "on-click": "timew stop && pkill -RTMIN+10 waybar",
        "on-click-right": "timew continue && pkill -RTMIN+10 waybar"
    },

    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", ""]
        },
        "on-click": "pavucontrol"
	}
}

